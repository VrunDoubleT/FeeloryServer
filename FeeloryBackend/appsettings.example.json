{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "YOUR_SUPER_SECRET_JWT_KEY_HERE",
    "Issuer": "FeeloryAPI",
    "Audience": "FeeloryClient",
    "ExpiresMinutes": 60,
    "RefreshTokenExpiresDays": 30
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1435;Database=FeeloryDB;User Id=sa;Password=YOUR_SA_PASSWORD_HERE;TrustServerCertificate=True;"
  },
  "Redis": {
    "ConnectionString": "localhost:6379,password=YOUR_REDIS_PASSWORD_HERE"
  },
  "EmailSettings": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "Username": "your_email@gmail.com",
    "Password": "your_app_password_here",
    "EnableSsl": true,
    "FromEmail": "your_email@gmail.com"
  },
  "Cloudinary": {
    "CloudName": "your_cloud_name_here",
    "ApiKey": "your_api_key_here",
    "ApiSecret": "your_api_secret_here"
  },
  "RabbitMQ": {
    "Host": "localhost",
    "Port": 5672,
    "UserName": "your_rabbitmq_username",
    "Password": "your_rabbitmq_password",
    "VirtualHost": "/"
  }
}